# Firebase Configuration (Required)
# These variables are used to connect to your Firebase project
# Get these values from your Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_DATABASE_ID=(default)

# GitHub API Token (Optional — set in Vercel env vars, NOT with VITE_ prefix)
# Vercel automatically provides this for GitHub-linked projects
# You can also set it manually for higher rate limits (5000/hour vs 60/hour)
# Get a token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# Note: All other platforms (Codeforces, LeetCode, CodeChef, AtCoder)
# use public APIs that don't require authentication tokens
